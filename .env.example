# ─── SERVER ───────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── DATABASE ─────────────────────────────────────
# Get from: https://cloud.mongodb.com (Free 512MB)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/apkaswaad?retryWrites=true&w=majority

# ─── JWT SECRETS ──────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_too
JWT_REFRESH_EXPIRES_IN=30d

# ─── REDIS (Optional - for caching) ───────────────
# Get from: https://upstash.com (Free 10k requests/day)
REDIS_URL=redis://default:password@your-redis-host:6379
REDIS_ENABLED=false

# ─── RAZORPAY ─────────────────────────────────────
# Get from: https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxx

# ─── FRONTEND URL ─────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Production: https://apkaswaad.in

# ─── ADMIN ────────────────────────────────────────
ADMIN_EMAIL=admin@apkaswaad.in
ADMIN_PASSWORD=Admin@123456
